        <!--<div class="link-group">
          <h4 class="link-title">AI</h4>
          <ul class="link-list">
            <li><a href="#windows">Descubre Inled AI </a></li>
          </ul>
        </div> -->

        <div class="link-group">
          <h4 class="link-title" data-i18n="landing.footer.support">Soporte</h4>
          <ul class="link-list">
            <li><a href="https://help.inled.es" data-i18n="landing.footer.help">Centro de ayuda</a></li>
            <li><a href="https://help.inled.es" data-i18n="landing.footer.tutorials">Tutoriales</a></li>
